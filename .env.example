# LiftLog user configuration — copy to .env.local and edit.
# .env.local is gitignored; no personal data belongs in the repo.
#
# Fields per user:
#   id        stable key for the user's data (don't change after first run)
#   name      display name
#   email     shown in Settings; matches the Cloudflare Access identity when deployed
#   accent    "blue" | "green" (IWF plate colors)
#   unit      "kg" | "lb"
#   template  "fiveByFive" (program mode, auto progression) | "routine" (Strong-style)
#   workingWeights  fiveByFive only — starting kg per slot:
#                   squatA, bench, row, dips, squatB, ohp, deadlift, pullups, chinups
NEXT_PUBLIC_LIFTLOG_USERS=[{"id":"user-1","name":"Lifter One","email":"lifter-one@example.com","accent":"blue","unit":"kg","template":"fiveByFive","workingWeights":{"squatA":20,"bench":20,"row":30,"dips":0,"squatB":20,"ohp":20,"deadlift":40,"pullups":0,"chinups":0}},{"id":"user-2","name":"Lifter Two","email":"lifter-two@example.com","accent":"green","unit":"kg","template":"routine"}]
